<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- ============================================================ -->
	<!--  Colour tokens — Windows 11 dark theme                       -->
	<!-- ============================================================ -->
	<Color x:Key="AccentColor">#FF60CDFF</Color>
	<Color x:Key="AccentDarkColor">#FF99DAFF</Color>
	<Color x:Key="AccentLightColor">#FF004E8C</Color>
	<Color x:Key="SurfaceColor">#FF202020</Color>
	<Color x:Key="CardColor">#FF2C2C2C</Color>
	<Color x:Key="SubtleColor">#FF383838</Color>
	<Color x:Key="StrokeColor">#FF454545</Color>
	<Color x:Key="ForegroundColor">#FFFAFAFA</Color>
	<Color x:Key="SecondaryForegroundColor">#FFB0B0B0</Color>
	<Color x:Key="DisabledForegroundColor">#FF5A5A5A</Color>
	<Color x:Key="ErrorColor">#FFFF99A4</Color>

	<SolidColorBrush x:Key="AccentBrush"              Color="{StaticResource AccentColor}"/>
	<SolidColorBrush x:Key="AccentDarkBrush"          Color="{StaticResource AccentDarkColor}"/>
	<SolidColorBrush x:Key="AccentLightBrush"         Color="{StaticResource AccentLightColor}"/>
	<SolidColorBrush x:Key="SurfaceBrush"             Color="{StaticResource SurfaceColor}"/>
	<SolidColorBrush x:Key="CardBrush"                Color="{StaticResource CardColor}"/>
	<SolidColorBrush x:Key="SubtleBrush"              Color="{StaticResource SubtleColor}"/>
	<SolidColorBrush x:Key="StrokeBrush"              Color="{StaticResource StrokeColor}"/>
	<SolidColorBrush x:Key="ForegroundBrush"          Color="{StaticResource ForegroundColor}"/>
	<SolidColorBrush x:Key="SecondaryForegroundBrush" Color="{StaticResource SecondaryForegroundColor}"/>
	<SolidColorBrush x:Key="DisabledForegroundBrush"  Color="{StaticResource DisabledForegroundColor}"/>

</ResourceDictionary>