<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- ============================================================ -->
	<!--  Colour tokens — Windows 11 light theme                      -->
	<!-- ============================================================ -->
	<Color x:Key="AccentColor">#FF0078D4</Color>
	<Color x:Key="AccentDarkColor">#FF005A9E</Color>
	<Color x:Key="AccentLightColor">#FFB4D8F9</Color>
	<Color x:Key="SurfaceColor">#FFF3F3F3</Color>
	<Color x:Key="CardColor">#FFFFFFFF</Color>
	<Color x:Key="SubtleColor">#FFE9E9E9</Color>
	<Color x:Key="StrokeColor">#FFD1D1D1</Color>
	<Color x:Key="ForegroundColor">#FF1A1A1A</Color>
	<Color x:Key="SecondaryForegroundColor">#FF666666</Color>
	<Color x:Key="DisabledForegroundColor">#FFABABAB</Color>
	<Color x:Key="ErrorColor">#FFC42B1C</Color>

	<SolidColorBrush x:Key="AccentBrush"              Color="{StaticResource AccentColor}"/>
	<SolidColorBrush x:Key="AccentDarkBrush"          Color="{StaticResource AccentDarkColor}"/>
	<SolidColorBrush x:Key="AccentLightBrush"         Color="{StaticResource AccentLightColor}"/>
	<SolidColorBrush x:Key="SurfaceBrush"             Color="{StaticResource SurfaceColor}"/>
	<SolidColorBrush x:Key="CardBrush"                Color="{StaticResource CardColor}"/>
	<SolidColorBrush x:Key="SubtleBrush"              Color="{StaticResource SubtleColor}"/>
	<SolidColorBrush x:Key="StrokeBrush"              Color="{StaticResource StrokeColor}"/>
	<SolidColorBrush x:Key="ForegroundBrush"          Color="{StaticResource ForegroundColor}"/>
	<SolidColorBrush x:Key="SecondaryForegroundBrush" Color="{StaticResource SecondaryForegroundColor}"/>
	<SolidColorBrush x:Key="DisabledForegroundBrush"  Color="{StaticResource DisabledForegroundColor}"/>

</ResourceDictionary>