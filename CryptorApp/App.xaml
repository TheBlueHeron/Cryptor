<Application x:Class="CryptorApp.App" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CryptorApp"
             StartupUri="Views/MainWindow.xaml">
	<Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>				
				<ResourceDictionary Source="Themes/Win11LightColors.xaml"/><!-- [0] Colour tokens — swapped at runtime by App.xaml.cs for dark/light -->				
				<ResourceDictionary Source="Themes/Win11Theme.xaml"/><!-- [1] Control templates (all use DynamicResource) -->
			</ResourceDictionary.MergedDictionaries>
			<BooleanToVisibilityConverter x:Key="BoolToVis"/>
		</ResourceDictionary>
	</Application.Resources>
</Application>