<UserControl x:Class="CryptorApp.Views.CryptSettings" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:CryptorApp.Views" mc:Ignorable="d" d:DesignWidth="800"
			 DataContext="{Binding RelativeSource={RelativeSource Mode=Self}, Path=SettingsViewModel}">
    <Grid Margin="0">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" MinHeight="36"/>
			<RowDefinition Height="16"/>
			<RowDefinition Height="Auto" MinHeight="36"/>
			<RowDefinition Height="16"/>
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*"/>
			<ColumnDefinition Width="7*"/>
		</Grid.ColumnDefinitions>
		<Label VerticalContentAlignment="Center" Content="Key" FontWeight="Bold"/>
		<PasswordBox Grid.Column="1" HorizontalAlignment="Stretch" VerticalContentAlignment="Center"
					 local:PasswordBoxHelper.MonitorPassword="True"
					 local:PasswordBoxHelper.SecurePassword="{Binding Key}" />
		<Label Grid.Row="2" VerticalContentAlignment="Center" Content="Iv" FontWeight="Bold"/>
		<PasswordBox Grid.Row="2" Grid.Column="1" HorizontalAlignment="Stretch" VerticalContentAlignment="Center"
					 local:PasswordBoxHelper.MonitorPassword="True"
					 local:PasswordBoxHelper.SecurePassword="{Binding Iv}" />
	</Grid>
</UserControl>
