<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d"
		x:Class="CryptorApp.Views.MainWindow" xmlns:local="clr-namespace:CryptorApp" xmlns:Behaviors="http://schemas.microsoft.com/xaml/behaviors" xmlns:Specialized="clr-namespace:System.Collections.Specialized;assembly=System.Collections.Specialized"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}, Path=MainViewModel}"
		Title="Cryptor" Height="400" Width="800" MinHeight="240" MinWidth="480" WindowStartupLocation="CenterScreen" FontSize="14" ResizeMode="CanResizeWithGrip">
	<Window.Effect>
		<DropShadowEffect Opacity="0.66" BlurRadius="7" ShadowDepth="2" RenderingBias="Quality" Color="#FF1166DD"/>
	</Window.Effect>
	<Grid Margin="0,12,12,0">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" MinHeight="36"/>
			<RowDefinition Height="16"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto" MinHeight="36"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="16"/>
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*"/>
			<ColumnDefinition Width="7*"/>
		</Grid.ColumnDefinitions>
		<Label VerticalContentAlignment="Center" FontWeight="Bold" Content="Type"/>
		<ComboBox Grid.Column="1" ItemsSource="{Binding Converters, Mode=OneTime}" DisplayMemberPath="Name" VerticalAlignment="Center" FontWeight="Bold" MinHeight="36" SelectedItem="{Binding CurrentCryptor, Mode=TwoWay}" VerticalContentAlignment="Center">
			<Behaviors:Interaction.Triggers>
				<Behaviors:EventTrigger EventName="SelectionChanged">
					<Behaviors:InvokeCommandAction Command="{Binding Select}" />
				</Behaviors:EventTrigger>
			</Behaviors:Interaction.Triggers>
		</ComboBox>
		<ContentControl Grid.ColumnSpan="2" Grid.Row="2" Content="{Binding CurrentSettings, Mode=OneWay}"/>
		<Label Grid.Row="3" VerticalContentAlignment="Center" FontWeight="Bold" Content="Input"/>
		<TextBox Grid.Column="1" Grid.Row="3" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" BorderThickness="1" Text="{Binding Input, Mode=TwoWay}"/>
		<Button ToolTip="Convert..." Command="{Binding Convert}" FontFamily="Marlett" FontSize="26" Cursor="Hand" Content="6" Grid.Column="1" Grid.Row="4" HorizontalAlignment="Center" VerticalAlignment="Center" Width="30" Height="30"/>
		<Label Grid.Row="5" VerticalContentAlignment="Center" FontWeight="Bold" Content="Output"/>
		<TextBox Grid.Column="1" Grid.Row="5" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" BorderThickness="1" IsReadOnly="True" IsReadOnlyCaretVisible="True" Text="{Binding Output, Mode=TwoWay}"/>
		<TextBlock Grid.Row="6" Grid.Column="1" Padding="0,0,0,2" VerticalAlignment="Bottom" Text="{Binding Status, Mode=OneWay}" ToolTip="{Binding Status, Mode=OneWay}" FontSize="10" TextOptions.TextRenderingMode="ClearType" TextTrimming="CharacterEllipsis"/>
	</Grid>
</Window>