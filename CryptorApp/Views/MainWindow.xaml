<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d"
		x:Class="CryptorApp.Views.MainWindow" xmlns:local="clr-namespace:CryptorApp" xmlns:Behaviors="http://schemas.microsoft.com/xaml/behaviors"
		xmlns:res="clr-namespace:CryptorApp.Resources"
		DataContext="{Binding RelativeSource={RelativeSource Mode=Self}, Path=MainViewModel}"
		Title="{x:Static res:Strings.Window_Title}" Height="530" Width="840" MinHeight="428" MinWidth="670"
		WindowStartupLocation="CenterScreen" FontSize="14" ResizeMode="CanResizeWithGrip"
		Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource ForegroundBrush}" FontFamily="Segoe UI Variable Text, Segoe UI, sans-serif">
	<Window.Effect>
		<DropShadowEffect Opacity="0.14" BlurRadius="16" ShadowDepth="4" Color="#FF000000"/>
	</Window.Effect>
	<DockPanel>
		<!-- === Status bar === -->
		<TextBlock DockPanel.Dock="Bottom"
				   Name="txtStatus"
				   Margin="84,0,20,12"
				   VerticalAlignment="Bottom"
				   Text="{Binding Status, Mode=OneWay}"
				   ToolTip="{Binding Status, Mode=OneWay}"
				   Foreground="{Binding StatusColor, Mode=OneWay}"
				   FontSize="11"
				   TextTrimming="CharacterEllipsis"/>
		<!-- === Main content === -->
		<ScrollViewer x:Name="rootScroller"
					  VerticalScrollBarVisibility="Auto"
					  HorizontalScrollBarVisibility="Disabled" Padding="0,20,0,12">
			<Grid Margin="20,0,20,0"
				  MinHeight="{Binding ViewportHeight, ElementName=rootScroller}">
				<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/><!-- Type selector row -->
				<RowDefinition Height="12"/><!-- gap -->
				<RowDefinition Height="Auto"/><!-- Mode selector row -->
				<RowDefinition Height="12"/><!-- gap -->
				<RowDefinition Height="Auto"/><!-- Settings card (collapsed when empty) -->
				<RowDefinition Height="8"/><!-- gap -->
				<RowDefinition Height="*" MinHeight="72"/><!-- Input label + box -->
				<RowDefinition Height="44"/><!-- gap + convert button row -->
				<RowDefinition Height="*" MinHeight="72"/><!-- Output label + box -->
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" MinWidth="64"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>
			<!-- === Row 0 : Type selector === -->
			<Label VerticalContentAlignment="Center" FontWeight="SemiBold" Content="{x:Static res:Strings.Label_Type}" Margin="0,0,16,0"/>
			<ComboBox Grid.Column="1"
					  ItemsSource="{Binding Converters, Mode=OneWay}"
					  DisplayMemberPath="Name"
					  SelectedItem="{Binding CurrentCryptor, Mode=TwoWay}">
				<Behaviors:Interaction.Triggers>
					<Behaviors:EventTrigger EventName="SelectionChanged">
						<Behaviors:InvokeCommandAction Command="{Binding SelectCommand}" />
					</Behaviors:EventTrigger>
				</Behaviors:Interaction.Triggers>
			</ComboBox>
			<!-- === Row 2 : Mode selector === -->
			<Label Grid.Row="2" VerticalContentAlignment="Center" FontWeight="SemiBold" Content="{x:Static res:Strings.Label_Mode}" Margin="0,0,16,0"/>
			<StackPanel Grid.Row="2"
						Grid.Column="1"
						Orientation="Horizontal">
				<RadioButton GroupName="ModeGroup" Command="{Binding ModeCommand}" IsChecked="True" CommandParameter="{x:Static local:CryptMode.Decode}" Content="{x:Static res:Strings.Radio_Decode}" Margin="0,0,16,0" VerticalContentAlignment="Center"/>
				<RadioButton GroupName="ModeGroup" Command="{Binding ModeCommand}" CommandParameter="{x:Static local:CryptMode.Encode}" Content="{x:Static res:Strings.Radio_Encode}" VerticalContentAlignment="Center"/>
			</StackPanel>
			<!-- === Row 4 : Settings card === -->
			<Border Grid.Row="4" Grid.Column="1"
					Background="{DynamicResource CardBrush}"
					BorderBrush="{DynamicResource StrokeBrush}"
					BorderThickness="1"
					CornerRadius="6"
					Padding="16,12">
				<Border.Style>
					<Style TargetType="Border">
						<Setter Property="Visibility" Value="Visible"/>
						<Setter Property="Effect">
							<Setter.Value>
								<DropShadowEffect Opacity="0.06" BlurRadius="6" ShadowDepth="1" Color="#FF000000"/>
							</Setter.Value>
						</Setter>
						<Style.Triggers>
							<DataTrigger Binding="{Binding CurrentSettings}" Value="{x:Null}">
								<Setter Property="Visibility" Value="Collapsed"/>
							</DataTrigger>
						</Style.Triggers>
					</Style>
				</Border.Style>
				<ContentControl Content="{Binding CurrentSettings, Mode=OneWay}"/>
			</Border>
			<!-- === Row 6 : Input === -->
			<Label Grid.Row="6" VerticalContentAlignment="Top" FontWeight="SemiBold" Content="{x:Static res:Strings.Label_Input}" Margin="0,8,16,0"/>
			<TextBox Grid.Column="1"
					 Grid.Row="6"
					 TextWrapping="Wrap"
					 AcceptsReturn="True"
					 Text="{Binding Input, Mode=TwoWay}"/>
			<!-- === Row 7 : Convert button === -->
			<Button Grid.Row="7" Grid.Column="1"
					Command="{Binding ConvertCommand}"
					HorizontalAlignment="Center" VerticalAlignment="Center"
					Width="120" Height="32"
					ToolTip="{x:Static res:Strings.Button_Convert_Tooltip}">
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="&#x2193;" FontSize="15" Margin="0,0,6,0" Foreground="White"/>
						<TextBlock Text="{x:Static res:Strings.Button_Convert}" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
				</StackPanel>
			</Button>
			<!-- === Row 8 : Output === -->
			<Label Grid.Row="8" VerticalContentAlignment="Top" FontWeight="SemiBold" Content="{x:Static res:Strings.Label_Output}" Margin="0,8,16,0"/>
			<TextBox Grid.Column="1" Grid.Row="8"
					 TextWrapping="Wrap"
					 IsReadOnly="True"
					 IsReadOnlyCaretVisible="True"
					 Text="{Binding Output, Mode=TwoWay}"/>
			</Grid>
		</ScrollViewer>
	</DockPanel>
</Window>